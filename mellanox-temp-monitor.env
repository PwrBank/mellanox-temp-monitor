# One or more Mellanox MST device paths, separated by spaces.
DEVICES="${DEVICES:-/dev/mst/mt4127_pciconf0}"

# Temperature threshold in Celsius.
THRESHOLD_C="${THRESHOLD_C:-80}"

# How often to poll the card temperature.
POLL_INTERVAL_SEC="${POLL_INTERVAL_SEC:-60}"

# When the card stays above threshold, send a reminder this often.
# Set to 0 to log only on threshold crossing and recovery.
REMINDER_INTERVAL_SEC="${REMINDER_INTERVAL_SEC:-900}"

# Start the Mellanox MST service automatically before monitoring.
MST_AUTOSTART="${MST_AUTOSTART:-1}"

# Optional overrides.
# MGET_TEMP_BIN=/usr/bin/mget_temp
# MST_BIN=/usr/bin/mst
# SYSLOG_TAG=mellanox-temp-monitor
# SYSLOG_FACILITY=daemon
# DEBUG_STDERR=0
